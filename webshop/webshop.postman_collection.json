{
  "info": {
    "name": "MiniShop API",
    "_postman_id": "b5d2c2b2-1c7e-4f0c-8f45-3c1f6a4f8a1e",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Products - list",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/products",
          "host": ["{{baseUrl}}"],
          "path": ["products"]
        }
      }
    },
    {
      "name": "Products - by id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/products/p1",
          "host": ["{{baseUrl}}"],
          "path": ["products", "p1"]
        }
      }
    },
    {
      "name": "Products - create (auth required)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Új termék\",\n  \"priceHuf\": 1234,\n  \"imageUrl\": \"https://picsum.photos/seed/new/800/600\",\n  \"description\": \"Egy új termék leírása.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/products",
          "host": ["{{baseUrl}}"],
          "path": ["products"]
        }
      }
    },
    {
      "name": "Products - update (auth required)",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Frissített termék\",\n  \"priceHuf\": 2000,\n  \"imageUrl\": \"https://picsum.photos/seed/updated/800/600\",\n  \"description\": \"Frissített termék leírása.\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/products/p1",
          "host": ["{{baseUrl}}"],
          "path": ["products", "p1"]
        }
      }
    },
    {
      "name": "Products - delete (auth required)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/products/p1",
          "host": ["{{baseUrl}}"],
          "path": ["products", "p1"]
        }
      }
    },
    {
      "name": "Auth - login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.token) {",
              "  pm.environment.set('token', json.token);",
              "  console.log('Token saved:', json.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"demo@demo.hu\",\n  \"password\": \"demo\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
    {
      "name": "Auth - register",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.token) {",
              "  pm.environment.set('token', json.token);",
              "  console.log('Token saved:', json.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "register"]
        }
      }
    }
  ]
}
