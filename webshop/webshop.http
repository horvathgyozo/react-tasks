### Variable definition
@baseUrl = http://localhost:3001
@token =

# -----------------------------------------
# HEALTH
# -----------------------------------------

### Health check
GET {{baseUrl}}/health
Accept: application/json

# -----------------------------------------
# PRODUCTS
# -----------------------------------------

### List products
GET {{baseUrl}}/products
Accept: application/json

### Get product by id
GET {{baseUrl}}/products/p1
Accept: application/json

### Create product (auth required)
POST {{baseUrl}}/products
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "name": "Uj termek",
  "priceHuf": 1234,
  "imageUrl": "https://picsum.photos/seed/new/800/600",
  "description": "Egy uj termek leirasa."
}

### Update product (auth required)
PUT {{baseUrl}}/products/p1
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{token}}

{
  "name": "Frissitett termek",
  "priceHuf": 2000,
  "imageUrl": "https://picsum.photos/seed/updated/800/600",
  "description": "Frissitett termek leirasa."
}

### Delete product (auth required)
DELETE {{baseUrl}}/products/p1
Accept: application/json
Authorization: Bearer {{token}}

# -----------------------------------------
# AUTH
# -----------------------------------------

### Login
# @name login
POST {{baseUrl}}/auth/login
Content-Type: application/json
Accept: application/json

{
  "email": "demo@demo.hu",
  "password": "demo"
}

### Save token from login response
@token = {{login.response.body.token}}

### Register
# @name register
POST {{baseUrl}}/auth/register
Content-Type: application/json
Accept: application/json

{
  "email": "test@example.com",
  "password": "password123"
}

### Optional: save token from register response instead
# @token = {{register.response.body.token}}
